# مفتاح Genspark (يفتح Claude/GPT-5/DeepSeek عبر بروكسي)
GENSPARK_API_KEY=ضع_مفتاح_genspark_هنا

# مفتاح OpenRouter (300+ نموذج، فيه مجاني) — اختياري
OPENROUTER_API_KEY=ضع_مفتاح_openrouter_هنا

# مفتاح وهمي للنموذج المحلي (Ollama لا يحتاج مفتاحاً حقيقياً)
DUMMY_LOCAL_KEY=ollama
